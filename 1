fromscapy.allimport*
packet=IP()/TCP()
e_pack=Ether()/packet
e_pack.show()

#!/bin/bash
target="8.8.8.8"
echo "Enter the starting port number:"
read port_start
echo "Enter the ending port number:"
read port_end
for ((port=port_start; port<=port_end; port++))
do
    echo "Scanning Port $port ..."
    nc -zv -w 1 $target $port 2>&1 | grep succeeded
done
